# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mergepay

# --- Server ---
PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Stellar (mainnet by default) ---
#   testnet: STELLAR_NETWORK=testnet  HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=public
HORIZON_URL=https://horizon.stellar.org

# Server SEP-10 signing key — generate one with: npm run gen:sep10key
SEP10_SIGNING_SECRET=
SEP10_HOME_DOMAIN=localhost:4000
WEB_AUTH_DOMAIN=localhost:4000

# --- Anchor (SEP-24) ---
# On mainnet, set this to a real production anchor you have onboarded with.
# The testanchor below ONLY works on testnet.
#   testnet: ANCHOR_HOME_DOMAIN=testanchor.stellar.org  ANCHOR_NAME="Stellar Test Anchor"
ANCHOR_HOME_DOMAIN=
ANCHOR_NAME=
ANCHOR_WEBHOOK_SECRET=change-me

# --- Stable asset (Circle's mainnet USDC by default) ---
#   testnet USDC issuer: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
STABLE_ASSET_CODE=USDC
STABLE_ASSET_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# --- Uploads ---
UPLOADS_DIR=./uploads
